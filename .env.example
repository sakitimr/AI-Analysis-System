# Doubao API Configuration (课题专用，请勿外泄)
# 在 TRAE IDE 中通过 .env 配置，.env 不纳入版本控制
DOUBAO_API_KEY=ark-your-api-key-here
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=your-model-endpoint-here

# Logging
LOG_LEVEL=INFO

# Optional: proxy for international search (Clash=7890, V2RayN=10809, SS=1080)
# SEARCH_PROXY=http://127.0.0.1:7890
